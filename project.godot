; Engine configuration file.
; Godot 4 project - Octo RPG (HD-2D style turn-based RPG)

config_version=5

[application]

config/name="Octo RPG"
config/description="aRPG 2D estilo HD-2D (Octopath) + combate dinamico estilo Darkest Dungeon."
run/main_scene="res://scenes/MainMenu.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://icon.svg"

[autoload]

PixelArt="*res://scripts/PixelArt.gd"
GameState="*res://scripts/GameState.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1280
window/size/window_height_override=720
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"

